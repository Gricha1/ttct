RUN echo "export LD_LIBRARY_PATH=\$LD_LIBRARY_PATH:/root/.mujoco/mujoco210/bin" >> ~/.bashrc
RUN echo "cd /usr/home/workspace/ttct && pip install -e ." >> ~/.bashrc
RUN echo "cd /usr/home/workspace/ && pip install -e ." >> ~/.bashrc
RUN echo "cd /usr/home/workspace" >> ~/.bashrc

