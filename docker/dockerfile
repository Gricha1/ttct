# Ubuntu base + Miniconda (Python 3.8). Avoids Debian Buster issues.
# Build with: docker build -t ttct_img -f docker/dockerfile .

FROM ubuntu:20.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PATH="/root/miniconda3/bin:$PATH"

# Install Miniconda with Python 3.8 via direct download
RUN apt-get update && apt-get install -y --no-install-recommends \
    wget ca-certificates \
    && wget -q https://repo.anaconda.com/miniconda/Miniconda3-py38_4.12.0-Linux-x86_64.sh -O /tmp/miniconda.sh \
    && bash /tmp/miniconda.sh -b -p /root/miniconda3 \
    && rm /tmp/miniconda.sh \
    && apt-get purge -y wget && apt-get autoremove -y && rm -rf /var/lib/apt/lists/*

RUN echo '\
   Acquire::Retries "100";\
   Acquire::https::Timeout "240";\
   Acquire::http::Timeout "240";\
   APT::Get::Assume-Yes "true";\
   APT::Install-Recommends "false";\
   APT::Install-Suggests "false";\
   Debug::Acquire::https "true";\
   ' > /etc/apt/apt.conf.d/99custom

# install mujoco (wget needed here; was removed after miniconda install)
RUN apt-get update
RUN apt-get install -y build-essential wget unzip git
RUN cd /root \
    && mkdir .mujoco \
    && wget https://mujoco.org/download/mujoco210-linux-x86_64.tar.gz \
    && tar -xf mujoco210-linux-x86_64.tar.gz -C .mujoco \
    && export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:/root/.mujoco/mujoco210/bin

# install mujoco_py
RUN apt-get install -y \
    libosmesa6-dev \
    patchelf
    #libgl1-mesa-dev \
    #libgl1-mesa-glx \
    #libglew-dev \
    #libosmesa6-dev \
    #software-properties-common \
    #patchelf
RUN pip install onnxruntime free-mujoco-py

# install torch with cuda support
RUN pip install torch==1.12.1+cu113 torchvision==0.13.1+cu113 torchaudio==0.12.1 --extra-index-url https://download.pytorch.org/whl/cu113 \
    && pip install tensorflow \
    && pip install wandb moviepy opencv-python

# fixed&additional pip deps
#RUN apt-get install libopenmpi-dev
#RUN pip install mpi4py
RUN pip install setuptools==65.5.0 "wheel<0.40.0"
RUN pip install gym
RUN pip install gymnasium==0.29.1
RUN pip install pandas==1.5.3
RUN pip install matplotlib==3.6.2
RUN pip install stable_baselines3==2.3.0 --no-deps
RUN pip install numpy==1.23.4
RUN pip install imageio-ffmpeg==0.4.9
RUN pip install scikit-learn==1.3.2

# Install Safety-Gym
#RUN mkdir -p /usr/home/workspace/safety-gym
#COPY safety-gym /usr/home/workspace/safety-gym
#RUN cd /usr/home/workspace/safety-gym \
#    && pip install -e .

# fix after safety gym installation
RUN pip install numpy==1.23.4

RUN pip install loguru num2words transformers tensorboardX loralib safepo safety_gymnasium

